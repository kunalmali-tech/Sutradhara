# Postgres connection string — used to store contact form submissions
# and read them in the /admin panel. Works with any Postgres provider
# (Neon, Supabase, Vercel Postgres, etc).
DATABASE_URL=

# Password required to sign in at /admin
ADMIN_PASSWORD=

# Long random string used to sign admin session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=
